# Check if any staged files are in the bundled/ directory
BUNDLED_FILES=$(git -c core.quotePath=false diff --cached --name-only | grep '^bundled/' || true)

if [ -n "$BUNDLED_FILES" ]; then
  echo ""
  echo "ERROR: You are trying to commit changes to the /bundled directory:"
  echo ""
  echo "$BUNDLED_FILES"
  echo ""
  echo "Everything in /bundled directory is generated by command yarn build:dev. So don't make any changes to /bundled directory."
  echo ""
  exit 1
fi
