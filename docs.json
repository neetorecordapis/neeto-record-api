{
  "$schema": "https://mintlify.com/docs.json",
  "name": "NeetoRecord API",
  "description": "NeetoRecord API docs guide to manage recordings from external channels",
  "theme": "mint",
  "colors": {
    "primary": "#10B981",
    "light": "#34D399",
    "dark": "#059669"
  },
  "logo": "/assets/logo.svg",
  "favicon": "/assets/favicon.svg",
  "navbar": {
    "links": [
      {
        "label": "Blog",
        "href": "https://www.neeto.com/neetorecord/blog"
      },
      {
        "label": "Help center",
        "href": "https://help.neetorecord.com/"
      },
      {
        "label": "NeetoRecord",
        "href": "https://neetorecord.com/"
      }
    ]
  },
  "footer": {
    "socials": {
      "x": "https://x.com/neetohq",
      "linkedin": "https://www.linkedin.com/company/neeto",
      "youtube": "https://www.youtube.com/channel/UCoQ3Kv2JdZ51WZJ3QFFcI9g",
      "slack": "https://www.launchpass.com/neetohq"
    }
  },
  "navigation": {
    "pages": [
      {
        "group": "Getting Started",
        "icon": "rocket",
        "pages": [
          "getting-started/introduction",
          "getting-started/identifying-subdomain",
          "getting-started/authentication",
          "getting-started/pagination",
          "getting-started/response-codes"
        ]
      },
      {
        "group": "Recordings",
        "icon": "video",
        "pages": [
          "api-reference/recordings/list"
        ]
      },
      {
        "group": "Team Members",
        "icon": "user-group",
        "pages": [
          "api-reference/team-members/list",
          "api-reference/team-members/get",
          "api-reference/team-members/add",
          "api-reference/team-members/update",
          "api-reference/team-members/remove"
        ]
      },
      {
        "group": "API v1 (Deprecated)",
        "icon": "clock-rotate-left",
        "pages": [
          "api-reference-v1/recordings/list",
          "api-reference-v1/team-members/list",
          "api-reference-v1/team-members/add",
          "api-reference-v1/team-members/update",
          "api-reference-v1/team-members/remove"
        ]
      }
    ]
  },
  "api": {
    "params": {
      "expanded": "all"
    },
    "playground": {
      "display": "interactive",
      "proxy": true
    },
    "examples": {
      "languages": ["curl", "javascript", "python"],
      "defaults": "all"
    }
  },
  "styling": {
    "eyebrows": "section",
    "codeblocks": "system"
  },
  "appearance": {
    "default": "light",
    "strict": true
  }
}
